@using Sandbox;
@using Sandbox.UI;
@using Ambi.MelonRacer;
@using System;
@using System.Linq;
@inherits PanelComponent
@namespace Sandbox

<root>
	<div class="melon-racer-hud">

		<div class="hud-section stats">
			@foreach ( var row in RaceRows )
			{
				<div class="stat-row">
					<span class="stat-label">@row.Label</span>
					<span class="stat-value">@row.Value</span>
				</div>
			}
		</div>

		<div class="hud-section stats">
			<div class="stat-row">
				<span class="stat-label">Laps:</span>
				<span class="stat-value">@CompletedLaps / @TotalLaps</span>
			</div>
		</div>
	</div>
</root>

@code
{
	private GameManager Manager => GameManager.Instance;
	private Melon LocalMelon => Scene.GetAllComponents<Melon>().FirstOrDefault( melon => !melon.IsProxy );

	private (string Label, string Value)[] RaceRows => new[]
	{
		("Race Time:", FormatTime( RaceTime )),
		("Active Segment:", LocalMelon?.ActiveSegmentId.ToString() ?? "n/a"),
		("Your Best Lap:", FormatTimeOrEmpty( LocalMelon?.BestLapTime ?? 0f )),
		("Your Last Lap:", FormatTimeOrEmpty( LocalMelon?.LastLapTime ?? 0f )),
		("Finished:", LocalMelon?.HasFinishedRace == true ? "yes" : "no")
	};

	private float RaceTime => Manager?.RaceElapsed ?? 0f;
	private int CompletedLaps => LocalMelon?.CompletedLaps ?? 0;
	private int TotalLaps => Manager?.TotalLaps ?? 0;

	private static string FormatTimeOrEmpty( float seconds )
	{
		return seconds > 0f ? FormatTime( seconds ) : "--:--:---";
	}

	private static string FormatTime( float seconds )
	{
		var time = TimeSpan.FromSeconds( Math.Max( 0f, seconds ) );
		return $"{time.Minutes:00}:{time.Seconds:00}:{time.Milliseconds:000}";
	}

	protected override int BuildHash()
	{
		var melon = LocalMelon;

		return HashCode.Combine(
			(int)(RaceTime * 10f),
			CompletedLaps,
			TotalLaps,
			melon?.ActiveSegmentId ?? -1,
			(int)((melon?.BestLapTime ?? 0f) * 1000f),
			(int)((melon?.LastLapTime ?? 0f) * 1000f),
			melon?.HasFinishedRace ?? false );
	}
}
