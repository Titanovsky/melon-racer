@using Sandbox;
@using Sandbox.UI;
@using Ambi.MelonRacer;
@using System.Collections.Generic;
@using System.Linq;
@inherits PanelComponent
@namespace Sandbox

@if ( !IsOpen )
	return;

<root>
	<div class="scoreboard">
		<div class="scoreboard-header">
			<div class="map-name">@MapName</div>
			<div class="online-count">Online: @Connections.Count</div>
		</div>

		<div class="player-list">
			@foreach ( var connection in Connections )
			{
				<div class="player-row">
					<img class="avatar" src="avatar:@connection.SteamId" onclick=@( () => OpenProfile( connection ) ) />
					<div class="player-name">@connection.DisplayName</div>
					<div class="player-ping">@FormatPing( connection )</div>
				</div>
			}
		</div>
	</div>
</root>

@code
{
	private bool IsOpen => Input.Down( "Score" );
	private GameManager Manager => GameManager.Instance;
	private List<Connection> Connections => Connection.All.ToList();

	private string MapName
	{
		get
		{
			var header = Manager?.CurrentMapInfo?.Header;
			if ( !string.IsNullOrWhiteSpace( header ) )
				return header;

			return Manager?.MapInstance.IsValid() == true
				? Manager.MapInstance.MapName
				: "Unknown Map";
		}
	}

	private static string FormatPing( Connection connection )
	{
		return $"{System.MathF.Round( connection.Ping )} ms";
	}

	private static void OpenProfile( Connection connection )
	{
		Game.Overlay.ShowPlayer( connection.SteamId );
	}

	protected override int BuildHash()
	{
		var hash = new System.HashCode();
		hash.Add( IsOpen );

		if ( !IsOpen )
			return hash.ToHashCode();

		hash.Add( MapName );
		hash.Add( Connections.Count );

		foreach ( var connection in Connections )
		{
			hash.Add( connection.SteamId );
			hash.Add( connection.DisplayName );
			hash.Add( System.MathF.Round( connection.Ping ) );
		}

		return hash.ToHashCode();
	}
}
